{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "pwa-node",
      "request": "launch",
      "name": "Debug API (index.js)",
      "program": "${workspaceFolder}/index.js",
      "cwd": "${workspaceFolder}",
      "skipFiles": ["<node_internals>/**"],
      "console": "internalConsole",
      "outputCapture": "std",
      "autoAttachChildProcesses": false
    },
    {
      "type": "pwa-node",
      "request": "attach",
      "name": "Attach to Node (port 9229)",
      "port": 9229,
      "restart": false,
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
